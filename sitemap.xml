---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
{% assign post_pages = site.pages | where: "layout", "post" | sort: "date" | reverse %}
{% assign production_url = "https://sayrolivares.github.io" %}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    {% assign static_pages = site.html_pages | where_exp: "page", "page.layout != 'post'" | sort: "url" %}
    {% for page in static_pages %}
    <url>
        <loc>{{ production_url }}{{ page.url | replace: '/index.html', '/' }}</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
    </url>
    {% endfor %}
    {% for post in post_pages %}
    <url>
        <loc>{{ production_url }}{{ post.url }}</loc>
        <lastmod>{{ post.date | date: "%Y-%m-%d" }}</lastmod>
    </url>
    {% endfor %}
</urlset>
