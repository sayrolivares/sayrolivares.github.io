---
layout: null
permalink: /feed.xml
---
<?xml version="1.0" encoding="UTF-8" ?>
{% assign post_pages = site.pages | where: "layout", "post" | sort: "date" | reverse %}
<rss version="2.0">
    <channel>
        <title>{{ site.title }} - Writing and Coding Blog</title>
        <link>{{ site.url }}/</link>
        <description>{{ site.description }}</description>
        <language>en-us</language>
        <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>

        {% for post in post_pages %}
        <item>
            <title>{{ post.title }}</title>
            <link>{{ site.url }}{{ post.url }}</link>
            <guid>{{ site.url }}{{ post.url }}</guid>
            <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
            <description>{{ post.og_description | default: post.description }}</description>
        </item>
        {% endfor %}
    </channel>
</rss>
